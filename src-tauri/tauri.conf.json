{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "league-jax",
  "version": "0.1.0",
  "identifier": "com.tarnishablec.league-jax",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:31420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "league-jax",
        "width": 1200,
        "height": 1000,
        "minHeight": 600,
        "minWidth": 800,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

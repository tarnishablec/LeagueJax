{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LeagueJax",
  "version": "0.1.70",
  "identifier": "com.tarnishablec.league-jax",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:31420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "features": []
  },
  "app": {
    "windows": [
      {
        "title": "MAIN",
        "width": 1450,
        "height": 1000,
        "minHeight": 600,
        "minWidth": 800,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0NTQ3Rjk1MjUyMTEzMTEKUldRUkV5RWxsWDlVOUxuRStqQ2RYNjhtMm9tbGhKUUgzKy9DK3VSTmhEazk4Qk1Za1NOQzZUL0IK",
      "endpoints": [
        "https://github.com/tarnishablec/LeagueJax/releases/latest/download/latest.json"
      ]
    }
  }
}

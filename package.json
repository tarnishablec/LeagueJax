{
  "name": "league-jax",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint:biome": "bunx biome check .",
    "lint:biome:fix": "bunx biome check --write .",
    "lint:clippy": "cargo clippy -- -D warnings",
    "lint:check_all": "bun run lint:biome && bun run lint:clippy",
    "lint:fix_all": "bun run lint:biome:fix && bun run lint:clippy",
    "typecheck": "tsc --noEmit",
    "sync_rs_types": "cd src-tauri && cargo test export_bindings && cd .. && bunx biome check --write ./src/bindings && bun run typecheck"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@floating-ui/react": "^0.27.19",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@thaterror/core": "^1.0.1",
    "@vanilla-extract/css": "^1.19.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/vite-plugin": "^5.2.0",
    "graphology": "^0.26.0",
    "i18next": "^25.8.19",
    "lucide-react": "^0.577.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router": "^7.13.1",
    "remeda": "^2.33.6",
    "swr": "^2.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@rollup/plugin-swc": "^0.4.0",
    "@swc/core": "^1.15.18",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "graphology-types": "^0.24.8",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}

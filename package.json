{
  "name": "league-jax",
  "private": true,
  "version": "0.1.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "bump:patch": "bun run ./scripts/bump-version.ts patch",
    "bump:minor": "bun run ./scripts/bump-version.ts minor",
    "bump:major": "bun run ./scripts/bump-version.ts major",
    "lint:biome": "bunx biome check .",
    "lint:biome:fix": "bunx biome check --write .",
    "lint:clippy": "cargo clippy",
    "lint:check_all": "bun run lint:biome && bun run lint:clippy",
    "lint:fix_all": "bun run lint:biome:fix && bun run lint:clippy",
    "typecheck": "tsc --noEmit",
    "generate_updater_manifest": "bun run ./scripts/generate-updater-manifest.ts",
    "sync_rs_types": "cd src-tauri && cargo test export_bindings && cd .. && bunx biome check --write ./src/bindings && bun run typecheck"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@dagrejs/dagre": "^3.0.0",
    "@floating-ui/react": "^0.27.19",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@thaterror/core": "^1.0.1",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@xyflow/react": "^12.10.2",
    "graphology": "^0.26.0",
    "i18next": "^26.0.8",
    "lucide-react": "^1.11.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "recharts": "^3.8.1",
    "remeda": "^2.33.7",
    "smol-toml": "^1.6.1",
    "swr": "^2.4.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@rollup/plugin-swc": "^0.4.0",
    "@swc/core": "^1.15.30",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "graphology-types": "^0.24.8",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
